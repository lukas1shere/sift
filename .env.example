# Sift — Environment Variables
# Copy to .env.local for local development

# Required for Phase 2+: Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for Phase 5: Stripe (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Required for Phase 3: Inngest (https://inngest.com)
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# Optional: override Playwright browser path
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Tier limits (Phase 2) — adjust without code changes
TIER_FREE_EXTRACTIONS_PER_MONTH=100
TIER_FREE_SOURCES=2
TIER_PRO_EXTRACTIONS_PER_MONTH=5000
TIER_PRO_SOURCES=50
TIER_TEAM_EXTRACTIONS_PER_MONTH=50000
TIER_TEAM_SOURCES=500
